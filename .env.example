# Copy this file to .env and fill in your credentials
# DO NOT commit .env to git

# Dune Analytics API (free tier — 1000 credits/month)
# Sign up: https://dune.com → Settings → API → Create API Key
DUNE_API_KEY=your_key_here

# The integer query ID from the URL of your saved Dune query
# e.g. https://dune.com/queries/3456789 → DUNE_QUERY_ID=3456789
# SQL to paste: see docs/dune_queries/whale_transactions.sql
DUNE_QUERY_ID=0

# Optional: override the whale USD threshold (default 1000000)
# WHALE_USD_THRESHOLD=1000000

# Reddit API
# Create app: https://www.reddit.com/prefs/apps (choose "script" type)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=whale_signals by /u/your_username

# CryptoPanic API (free tier — 1000 requests/day)
# Sign up: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_token_here

# CoinGecko (no key needed for free tier, but rate-limited)
# Used for historical ETH/USD prices
